# Copy to .env (gitignored) and fill in from the Cloudflare dashboard.
# R2 -> Manage R2 API Tokens -> Create API Token (Object Read & Write,
# scoped to the bucket below). The account ID is shown on the R2 overview
# page and inside the S3 endpoint URL.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=rrrag-data

# Stage 1+ — model APIs
# https://dashboard.voyageai.com (embeddings)
VOYAGE_API_KEY=
# https://platform.claude.com (generation)
ANTHROPIC_API_KEY=
